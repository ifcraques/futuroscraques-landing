import { motion } from 'framer-motion'

export default function Sponsors() {
  // Todos os patrocinadores e apoiadores em uma única lista
  const patrocinadores = [
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/UOL_logo.svg/150px-UOL_logo.svg.png', alt: 'UOL', h: 38, url: 'https://www.uol.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/Ecolab_logo.svg/120px-Ecolab_logo.svg.png', alt: 'Ecolab', h: 34, url: 'https://www.ecolab.com' },
    { src: 'https://upload.wikimedia.org/wikipedia/en/d/d7/Unipar_Logo.svg', alt: 'Unipar', h: 38, url: 'https://www.unipar.com' },
    { src: 'https://logo.clearbit.com/ntsinlogistica.com.br', alt: 'NTS', h: 38, url: 'https://www.ntsinlogistica.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/b/ba/Havan_Logo.svg/120px-Havan_Logo.svg.png', alt: 'Havan', h: 38, url: 'https://www.havan.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/en/d/d7/B3_Bolsa_de_Valores_logo.svg', alt: 'B3', h: 38, url: 'https://www.b3.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/1/15/Caixa_Econ%C3%B4mica_Federal.png/120px-Caixa_Econ%C3%B4mica_Federal.png', alt: 'Caixa Residencial', h: 38, url: 'https://www.caixa.gov.br' },
    { src: 'https://logo.clearbit.com/sankofort.com.br', alt: 'Sankonfort', h: 38, url: 'https://www.sankofort.com.br' },
    { src: 'https://logo.clearbit.com/engemet.com.br', alt: 'Engemet', h: 34, url: 'https://www.engemet.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/en/a/ab/Est%C3%A1cio_de_S%C3%A1_logo.png', alt: 'Estácio', h: 38, url: 'https://www.estacio.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/30/Freixenet_Logo.svg/150px-Freixenet_Logo.svg.png', alt: 'Freixenet', h: 38, url: 'https://www.freixenet.com' },
    { src: 'https://logo.clearbit.com/metalinox.com.br', alt: 'Metalinox', h: 38, url: 'https://www.metalinox.com.br' },
    { src: 'https://logo.clearbit.com/sonda.com.br', alt: 'Sonda Supermercados', h: 38, url: 'https://www.sonda.com.br' },
    { src: 'https://logo.clearbit.com/altre.com.br', alt: 'Altre', h: 38, url: 'https://www.altre.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/pt/e/e2/Droga_Raia_Logo.png', alt: 'Droga Raia', h: 38, url: 'https://www.drogaraia.com.br' },
    { src: 'https://logo.clearbit.com/panco.com.br', alt: 'Panco', h: 38, url: 'https://www.panco.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/en/2/2f/Coca-Cola_logo.svg', alt: 'Coca-Cola', h: 48, url: 'https://www.coca-colabrasil.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/en/1/1f/Votorantim_logo.svg', alt: 'Grupo Votorantim', h: 34, url: 'https://www.votorantim.com.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/1/19/PagBank_logo.svg/120px-PagBank_logo.svg.png', alt: 'PagBank', h: 34, url: 'https://www.pagbank.com.br' },
    { src: 'https://logo.clearbit.com/passeidireto.com', alt: 'Passei Direto', h: 34, url: 'https://www.passeidireto.com' },
    { src: 'https://logo.clearbit.com/ingresso.com', alt: 'Ingresso.com', h: 34, url: 'https://www.ingresso.com' },
  ]

  const realizacao = [
    { src: 'https://upload.wikimedia.org/wikipedia/en/e/e8/Universidade_Paulista_logo.svg', alt: 'UNIP', h: 90, url: 'https://www.unip.br' },
    { src: 'https://logo.clearbit.com/narnet.com.br', alt: 'NAR', h: 65, url: 'https://www.narnet.com.br' },
    { src: '/logos/lei-incentivo-esporte.svg', alt: 'Lei de Incentivo ao Esporte SP', h: 65, url: 'https://www.lei-incentivo-esporte-sp.sp.gov.br', noGrayscale: true },
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/2/23/Bandeira_do_estado_de_S%C3%A3o_Paulo.svg/150px-Bandeira_do_estado_de_S%C3%A3o_Paulo.svg.png', alt: 'Governo do Estado de São Paulo', h: 65, url: 'https://www.saopaulo.sp.gov.br' },
    { src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/b/b3/Brasao_Brasil.png/120px-Brasao_Brasil.png', alt: 'Ministério do Esporte', h: 65, url: 'https://www.gov.br/esporte' },
    { src: '/logos/cbc.svg', alt: 'CBC - Comitê Brasileiro de Clubes', h: 75, url: 'https://www.cbclubes.org.br', noGrayscale: true },
  ]

  const LogoItem = ({ l }) => (
    <motion.a
      href={l.url}
      target="_blank"
      rel="noopener noreferrer"
      style={{
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        cursor: 'pointer',
        textDecoration: 'none',
      }}
      whileHover={{ scale: 1.1 }}
      transition={{ duration: 0.3 }}
    >
      <img
        src={l.src}
        alt={l.alt}
        loading="lazy"
        title={`Clique para visitar ${l.alt}`}
        style={{
          height: l.h + 'px',
          maxWidth: '130px',
          objectFit: 'contain',
          filter: l.noGrayscale ? 'none' : 'grayscale(100%)',
          opacity: l.noGrayscale ? 1 : 0.65,
          transition: 'all 0.3s ease',
        }}
        onMouseEnter={(e) => {
          e.target.style.filter = 'grayscale(0%)'
          e.target.style.opacity = '1'
        }}
        onMouseLeave={(e) => {
          if (!l.noGrayscale) {
            e.target.style.filter = 'grayscale(100%)'
            e.target.style.opacity = '0.65'
          }
        }}
      />
    </motion.a>
  )

  return (
    <section id="sponsors-section" className="section" style={{ padding: '4rem 2rem' }}>
      <motion.h2
        className="section-title"
        style={{ textAlign: 'center' }}
        initial={{ opacity: 0, y: 30 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
      >
        Patrocinadores & Apoio
      </motion.h2>
      <motion.p
        className="section-subtitle"
        style={{ textAlign: 'center', margin: '0 auto 3rem' }}
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
      >
        Empresas e instituições que acreditam e investem na transformação através do esporte
      </motion.p>

      <motion.div
        style={{
          background: 'white', padding: '3rem 2rem', borderRadius: '25px',
          boxShadow: '0 15px 40px rgba(0,0,0,0.05)', border: '1px solid var(--border)',
          display: 'flex', flexDirection: 'column', gap: '2.5rem',
        }}
        initial={{ opacity: 0, scale: 0.95 }}
        whileInView={{ opacity: 1, scale: 1 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
      >
        <div>
          <h4 style={{ textAlign: 'center', color: 'var(--accent)', fontFamily: "'Outfit', sans-serif", fontWeight: 700, fontSize: '0.85rem', letterSpacing: '2px', textTransform: 'uppercase', marginBottom: '1.5rem' }}>PATROCINADORES</h4>
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: '2rem', justifyContent: 'center', alignItems: 'center' }}>
            {patrocinadores.map((l) => <LogoItem key={l.alt} l={l} />)}
          </div>
        </div>

        <hr style={{ border: 'none', borderTop: '1px solid var(--border)', margin: '0' }} />

        <div>
          <h4 style={{ textAlign: 'center', color: 'var(--accent)', fontFamily: "'Outfit', sans-serif", fontWeight: 700, fontSize: '0.85rem', letterSpacing: '2px', textTransform: 'uppercase', marginBottom: '1.5rem' }}>REALIZAÇÃO</h4>
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: '2rem', justifyContent: 'center', alignItems: 'center' }}>
            {realizacao.map((l) => <LogoItem key={l.alt} l={l} />)}
          </div>
        </div>
      </motion.div>
    </section>
  )
}
